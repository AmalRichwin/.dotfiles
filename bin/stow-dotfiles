#!/usr/bin/env bash
set -euo pipefail

DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
EXCLUDE_DIRS=(".git" "bin")

bold() { printf '\033[1m%s\033[0m' "$*"; }
green() { printf '\033[32m%s\033[0m' "$*"; }
yellow() { printf '\033[33m%s\033[0m' "$*"; }
red() { printf '\033[31m%s\033[0m' "$*"; }

resolve_home() {
  if [[ -n "${HOME:-}" && -d "$HOME" ]]; then
    printf '%s' "$HOME"
    return 0
  fi

  local home=""
  while true; do
    read -rp "$(bold "HOME is unset or invalid. Enter home directory: ")" home
    if [[ "$home" == "~" ]]; then
      home="${HOME:-}"
    elif [[ "$home" == "~/"* ]]; then
      home="${HOME:-}${home#~}"
    fi
    if [[ -z "$home" && -n "${USER:-}" && -d "/Users/$USER" ]]; then
      home="/Users/$USER"
    elif [[ -z "$home" && -n "${USER:-}" && -d "/home/$USER" ]]; then
      home="/home/$USER"
    fi
    if [[ -n "$home" && -d "$home" ]]; then
      printf '%s' "$home"
      return 0
    fi
    echo "$(red "Directory not found:") $home" >&2
  done
}

require_stow() {
  if ! command -v stow >/dev/null 2>&1; then
    echo "$(red "GNU Stow is not installed.")" >&2
    echo "Install it with: brew install stow" >&2
    exit 1
  fi
}

list_packages() {
  local entry
  for entry in "$DOTFILES_DIR"/*; do
    [[ -d "$entry" ]] || continue
    local name
    name="$(basename "$entry")"
    [[ "$name" == .* ]] && continue
    local excluded=0
    for skip in "${EXCLUDE_DIRS[@]}"; do
      [[ "$name" == "$skip" ]] && excluded=1 && break
    done
    [[ "$excluded" -eq 1 ]] && continue
    printf '%s\n' "$name"
  done | sort
}

package_status() {
  local pkg="$1"
  local pkg_dir="$DOTFILES_DIR/$pkg"
  local linked=0
  local total=0

  while IFS= read -r -d '' target; do
    total=$((total + 1))
    local rel="${target#"$pkg_dir"/}"
    local home_path="$TARGET_HOME/$rel"
    if [[ -L "$home_path" ]]; then
      linked=$((linked + 1))
    fi
  done < <(find "$pkg_dir" -mindepth 1 \( -type f -o -type l \) ! -path '*/.git/*' -print0 2>/dev/null)

  if [[ "$total" -eq 0 ]]; then
    echo "empty"
  elif [[ "$linked" -eq "$total" ]]; then
    echo "stowed"
  elif [[ "$linked" -eq 0 ]]; then
    echo "not stowed"
  else
    echo "partial"
  fi
}

print_packages() {
  local packages=("$@")
  local i=1
  local pkg
  for pkg in "${packages[@]}"; do
    local status
    status="$(package_status "$pkg")"
    case "$status" in
      stowed) status="$(green stowed)" ;;
      partial) status="$(yellow partial)" ;;
      not\ stowed) status="$(red not stowed)" ;;
      empty) status="$(yellow empty)" ;;
    esac
    printf '  %2d) %-12s [%s]\n' "$i" "$pkg" "$status"
    i=$((i + 1))
  done
}

pick_packages() {
  local packages=("$@")
  local selection=""

  while true; do
    echo
    print_packages "${packages[@]}"
    echo
    echo "Enter package numbers (e.g. 1 3), $(bold all), or $(bold q) to cancel:"
    read -rp "> " selection
    selection="$(printf '%s' "$selection" | tr '[:upper:]' '[:lower:]')"

    [[ "$selection" == "q" || -z "$selection" ]] && return 1

    if [[ "$selection" == "all" ]]; then
      PICKED=("${packages[@]}")
      return 0
    fi

    PICKED=()
    local token
    for token in $selection; do
      if [[ "$token" =~ ^[0-9]+$ ]] && (( token >= 1 && token <= ${#packages[@]} )); then
        PICKED+=("${packages[token - 1]}")
      else
        echo "$(red "Invalid selection:") $token" >&2
        continue 2
      fi
    done

    if ((${#PICKED[@]} > 0)); then
      return 0
    fi
  done
}

run_stow() {
  local mode="$1"
  shift
  local packages=("$@")
  local flags=()
  local verb="Stowing"

  case "$mode" in
    stow) flags=(-t "$TARGET_HOME") ;;
    unstow) flags=(-D -t "$TARGET_HOME"); verb="Unstowing" ;;
    restow) flags=(-R -t "$TARGET_HOME"); verb="Restowing" ;;
    dry-run) flags=(-n -v -t "$TARGET_HOME"); verb="Dry-run stowing" ;;
  esac

  local pkg
  for pkg in "${packages[@]}"; do
    echo
    echo "$(bold "$verb") $(green "$pkg") -> $TARGET_HOME"
    (cd "$DOTFILES_DIR" && stow "${flags[@]}" "$pkg")
  done
}

main_menu() {
  local packages=()
  local pkg

  while IFS= read -r pkg; do
    packages+=("$pkg")
  done < <(list_packages)

  if ((${#packages[@]} == 0)); then
    echo "$(red "No stow packages found in") $DOTFILES_DIR" >&2
    exit 1
  fi

  while true; do
    echo
    echo "$(bold "dotfiles stow")"
    echo "Repo:   $DOTFILES_DIR"
    echo "Target: $TARGET_HOME"
    echo
    echo "  1) Stow packages"
    echo "  2) Unstow packages"
    echo "  3) Restow packages (relink)"
    echo "  4) Dry-run stow"
    echo "  5) Change home directory"
    echo "  6) Quit"
    echo
    read -rp "Choose an action [1-6]: " action

    case "$action" in
      1|2|3|4)
        PICKED=()
        pick_packages "${packages[@]}" || continue
        case "$action" in
          1) run_stow stow "${PICKED[@]}" ;;
          2) run_stow unstow "${PICKED[@]}" ;;
          3) run_stow restow "${PICKED[@]}" ;;
          4) run_stow dry-run "${PICKED[@]}" ;;
        esac
        echo
        echo "$(green "Done.")"
        ;;
      5)
        TARGET_HOME="$(resolve_home)"
        echo "Using home directory: $TARGET_HOME"
        ;;
      6|q|Q)
        echo "Bye."
        exit 0
        ;;
      *)
        echo "$(red "Invalid choice.")" >&2
        ;;
    esac
  done
}

TARGET_HOME="$(resolve_home)"
require_stow
main_menu
